# Ollama connection (host.docker.internal reaches your Mac's Ollama from inside containers)
# Only needed when Ollama is the active LLM provider (the default)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=phi4-mini

# Encryption key for LLM API keys stored in PostgreSQL (AES-256 Fernet).
# CHANGE THIS to a long random string before using cloud LLM providers.
# Generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=rvtool-genesis-change-me-in-production

# Database (all defaults work — no changes needed)
DATABASE_URL=postgresql://rvtool:rvtool_password@db:5432/rvtooldb
POSTGRES_DB=rvtooldb
POSTGRES_USER=rvtool
POSTGRES_PASSWORD=rvtool_password
