# Ollama connection (host.docker.internal reaches your Mac's Ollama from inside containers)
# Only needed when Ollama is the active LLM provider (the default)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=phi4-mini

# Docker Model Runner (Docker Desktop ≥ 4.25 — OpenAI-compatible, port 9545)
# Set DMR_MODEL to the model name exactly as it appears in Docker Model Runner,
# e.g.  ai/phi4-mini   or   hf.co/microsoft/Phi-4-mini-instruct-GGUF
DMR_BASE_URL=http://host.docker.internal:9545
DMR_MODEL=

# HuggingFace Hub token (optional) — improves rate limits for the GGUF resolver.
# Public models work without a token. Get one at https://huggingface.co/settings/tokens
HF_TOKEN=

# Encryption key for LLM API keys stored in PostgreSQL (AES-256 Fernet).
# REQUIRED — the API will refuse to start if this is left at the default value.
# Must be at least 32 characters. Generate a strong key with either:
#   make generate-secret
#   openssl rand -hex 32
SECRET_KEY=rvtool-genesis-change-me-in-production

# Optional API bearer token. Leave blank (or omit) for home-network / local use.
# When set, every API request must include:  Authorization: Bearer <your-token>
# Also set VITE_API_TOKEN to the same value when rebuilding the frontend.
# Generate one: openssl rand -hex 32
# API_TOKEN=

# Comma-separated list of allowed CORS origins.
# Default works for local Docker (localhost). Add your machine's IP for network demos:
#   ALLOWED_ORIGINS=http://localhost:3001,http://192.168.1.x:3001
# ALLOWED_ORIGINS=http://localhost:3001

# Database (all defaults work — no changes needed)
DATABASE_URL=postgresql://rvtool:rvtool_password@db:5432/rvtooldb
POSTGRES_DB=rvtooldb
POSTGRES_USER=rvtool
POSTGRES_PASSWORD=rvtool_password
