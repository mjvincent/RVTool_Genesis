# No API key required — this app uses Ollama (local LLM) running on your Mac
# Ollama must be running with phi4-mini pulled: ollama pull phi4-mini

# Ollama connection (host.docker.internal reaches your Mac's Ollama from inside containers)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=phi4-mini

# Database (all defaults work — no changes needed)
DATABASE_URL=postgresql://rvtool:rvtool_password@db:5432/rvtooldb
POSTGRES_DB=rvtooldb
POSTGRES_USER=rvtool
POSTGRES_PASSWORD=rvtool_password
